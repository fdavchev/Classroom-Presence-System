# ══════════════════════════════════════════════════════════════
# Classroom Presence System — Environment Configuration
# Copy this file to `.env` and fill in your values.
# NEVER commit `.env` to version control.
# ══════════════════════════════════════════════════════════════

# ── Firebase ───────────────────────────────────────────────────
# Path to your downloaded service account key JSON file.
FIREBASE_SERVICE_ACCOUNT_KEY=serviceAccountKey.json

# ── JWT ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CPS_JWT_SECRET=CHANGE_ME_TO_A_RANDOM_256_BIT_HEX_STRING

# Token lifetime in seconds. Default: 28800 (8 hours)
JWT_EXPIRE_SECONDS=28800

# ── Server ─────────────────────────────────────────────────────
# Port uvicorn will bind to. Default: 8000
PORT=8000

# Set to "production" to disable /docs and /redoc
ENVIRONMENT=development
