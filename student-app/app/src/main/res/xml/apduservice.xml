<?xml version="1.0" encoding="utf-8"?>
<host-apdu-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/app_name"
    android:requireDeviceUnlock="false">

    <aid-group
        android:description="@string/app_name"
        android:category="other">
        <!--
            This is the AID (Application Identifier).
            Think of it as a unique phone number for our NFC service.
            The teacher app "dials" this exact number when it scans.
            Must be 7 bytes (14 hex characters).
        -->
        <aid-filter android:name="F039414814810 0" />
    </aid-group>

</host-apdu-service>